# ── Groq (free — console.groq.com) ───────────────────────────────────────────
# Models: Llama 3.3 70B, Llama 3.1 8B, DeepSeek R1 70B, Gemma 2 9B, Mixtral 8x7B
GROQ_API_KEY=your_groq_key_here

# ── Cerebras (free — cloud.cerebras.ai) ──────────────────────────────────────
# Models: Llama 3.1 8B, Llama 3.3 70B  |  World's fastest inference
CEREBRAS_API_KEY=your_cerebras_key_here

# ── SambaNova (free — cloud.sambanova.ai) ────────────────────────────────────
# Models: Llama 3.3 70B, DeepSeek R1 671B, Qwen 2.5 72B  |  No rate limit issues
SAMBANOVA_API_KEY=your_sambanova_key_here

# ── Ollama (local — no key needed) ───────────────────────────────────────────
# Install from ollama.com, then run: ollama pull llama3.2
