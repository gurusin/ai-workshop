# ── Groq (free — console.groq.com) ───────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ── Cerebras (free — cloud.cerebras.ai) ──────────────────────────────────────
CEREBRAS_API_KEY=your_cerebras_api_key_here

# ── SambaNova (free — cloud.sambanova.ai) ────────────────────────────────────
SAMBANOVA_API_KEY=your_sambanova_api_key_here

# ── The Odds API (free — the-odds-api.com) ───────────────────────────────────
# Sign up at https://the-odds-api.com → Dashboard → API Key
# Free tier: 500 requests/month
ODDS_API_KEY=your_odds_api_key_here

# ── OpenWeatherMap (free — openweathermap.org) ───────────────────────────────
# Sign up at https://home.openweathermap.org/users/sign_up → API Keys tab
# Free tier: 60 calls/min, current weather included
WEATHER_API_KEY=your_openweathermap_api_key_here
